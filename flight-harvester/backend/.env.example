# Database
# Use asyncpg. For remote databases, include sslmode=require.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flight_harvester

# Auth (Required)
# Generate a real secret: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE-WITH-OUTPUT-OF-openssl-rand-hex-32
ADMIN_EMAIL=admin@example.com
# Must be at least 12 characters. Never commit a real password.
ADMIN_PASSWORD=REPLACE-WITH-A-UNIQUE-ADMIN-PASSWORD
ADMIN_FULL_NAME=System Admin

# App
DEBUG=false
# For local dev: http://localhost:5173
# For production: https://yourdomain.com
CORS_ORIGINS=["http://localhost:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1","test","backend","frontend"]

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# Flight Data Providers
# SerpAPI Google Flights - real-time accurate prices
SERPAPI_KEY=
SERPAPI_DEEP_SEARCH=true

# Demo mode - only for local demos/testing. Keep false in production.
DEMO_MODE=false

# Scraping tuning
# SCRAPE_BATCH_SIZE=10
# SCRAPE_DELAY_SECONDS=1.0
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
SCRAPE_RATE_LIMIT_ATTEMPTS=3
SCRAPE_RATE_LIMIT_WINDOW_SECONDS=300

# Monitoring (optional)
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
